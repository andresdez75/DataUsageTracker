<?xml version="1.0" encoding="utf-8"?>
<!--
    item_app_usage.xml
    App list row with icon, name, FG/BG usage and progress bar.
    The progress bar visually represents the % of background usage.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardElevation="1dp"
    app:cardCornerRadius="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Top row: icon + name + total -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- App icon -->
            <ImageView
                android:id="@+id/ivAppIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="App icon"/>

            <!-- App name -->
            <TextView
                android:id="@+id/tvAppName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Total usage -->
            <TextView
                android:id="@+id/tvTotalBytes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
        </LinearLayout>

        <!-- Bottom row: FG / BG / % BG -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="52dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvFgBytes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="@color/primary_blue"/>

            <TextView
                android:id="@+id/tvBgBytes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/tvBgRatio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Sessions -->
        <TextView
            android:id="@+id/tvSessions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="52dp"
            android:layout_marginBottom="6dp"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"/>

        <!-- Progress bar: % background usage -->
        <ProgressBar
            android:id="@+id/progressBg"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginStart="52dp"
            android:max="100"
            android:progress="0"/>

        <!-- Chart hint icon -->
        <ImageView
            android:id="@+id/ivChartHint"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginTop="6dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_bar_chart"
            android:contentDescription="View daily chart"/>

        <!-- Expandable daily chart container -->
        <FrameLayout
            android:id="@+id/chartContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
