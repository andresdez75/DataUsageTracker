<?xml version="1.0" encoding="utf-8"?>
<!--
    item_app_usage.xml
    Fila de la lista de apps con icono, nombre, consumo FG/BG y barra de progreso.
    La barra de progreso representa visualmente el % de consumo en background.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardElevation="1dp"
    app:cardCornerRadius="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Fila superior: icono + nombre + total -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Ranking -->
            <TextView
                android:id="@+id/tvRank"
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:textAlignment="center"/>

            <!-- Icono de la app -->
            <ImageView
                android:id="@+id/ivAppIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="App icon"/>

            <!-- Nombre de la app -->
            <TextView
                android:id="@+id/tvAppName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Consumo total -->
            <TextView
                android:id="@+id/tvTotalBytes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
        </LinearLayout>

        <!-- Fila inferior: FG / BG / % BG -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="84dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvFgBytes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="@color/primary_blue"/>

            <TextView
                android:id="@+id/tvBgBytes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/tvBgRatio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Barra de progreso: % consumo en background -->
        <ProgressBar
            android:id="@+id/progressBg"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginStart="84dp"
            android:max="100"
            android:progress="0"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
